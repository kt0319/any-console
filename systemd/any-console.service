# デプロイ時に ${USER}, ${INSTALL_DIR} を sed 等で置換すること
[Unit]
Description=any-console API
After=network.target

[Service]
User=${USER}
WorkingDirectory=${INSTALL_DIR}
EnvironmentFile=${INSTALL_DIR}/.env
ExecStart=/usr/bin/python3 -m api.main
KillMode=process
Restart=always
RestartSec=3
NoNewPrivileges=no
ProtectSystem=no
ProtectHome=no
MemoryMax=2G
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target
