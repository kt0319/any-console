# デプロイ時に ${USER}, ${INSTALL_DIR} を sed 等で置換すること
[Unit]
Description=pi-console API
After=network.target

[Service]
User=${USER}
WorkingDirectory=${INSTALL_DIR}
EnvironmentFile=${INSTALL_DIR}/.env
ExecStart=/usr/bin/python3 -m api.main
KillMode=process
Restart=always
RestartSec=3
NoNewPrivileges=no
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=${INSTALL_DIR} ${HOME} /tmp
MemoryMax=512M
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target
