# 認証トークン（必須）
# 以下のコマンドでランダム生成できます:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
PI_CONSOLE_TOKEN=your-secret-token

# ポート番号（デフォルト: 8888）
# PI_CONSOLE_PORT=8888

# ワークスペースルートディレクトリ（デフォルト: ~/work）
# PI_CONSOLE_WORKSPACE_ROOT=/home/user/work

# SSL証明書（任意・HTTPS使用時）
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem
